# Greenlight Cinema — Environment Variables
# Copy to .env and customize as needed

# Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:4b

# Embedding model
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Agent workflow
MAX_ITERATIONS=3
TARGET_SCORE=0.7
SYNOPSIS_WORDS=150

# Analytics
MIN_FILMS_FOR_RANKING=5
ROI_OUTLIER_CAP=100.0

# API
API_HOST=0.0.0.0
API_PORT=8000
RATE_LIMIT=50/minute

# DuckDB
DUCKDB_THREADS=4
